generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Dataset {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  name        String
  s3Key       String     @unique
  s3Bucket    String
  mimeType    String
  sizeBytes   BigInt
  source      String     @default("upload")
  sourceKey   String?
  rowCount    Int?
  columnCount Int?
  columns     Json?
  profileMeta Json?
  status      String     @default("pending")
  errorMsg    String?
  userId      String?
  runs        AgentRun[]
  user        User?      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("datasets")
}

model AgentRun {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  datasetId          String
  status             String   @default("analyzing")
  adfiScore          Float?
  complianceStatus   String?
  task               String?
  result             Json?
  analysis           Json?
  syntheticDataS3Key String?
  errorMsg           String?
  dataset            Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId])
  @@map("agent_runs")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  googleId  String?   @unique
  firstName String?
  lastName  String?
  picture   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  datasets  Dataset[]
}

model PolicyConfig {
  id          String   @id @default(cuid())
  datasetId   String   @unique   // "global" or a real dataset cuid
  config      Json                // StoredPolicyConfig shape
  attachedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("policy_configs")
}
