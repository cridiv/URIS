# Database
DATABASE_URL="postgresql://user:password@localhost:5432/uris?schema=public"

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGINS=https://uris-nu.vercel.app
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=https://uris-nu.vercel.app
FRONTEND_AUTH_CALLBACK_URL=https://uris-nu.vercel.app/auth/callback
FRONTEND_AUTH_SUCCESS_URL=https://uris-nu.vercel.app/Datasets
FRONTEND_AUTH_ERROR_URL=https://uris-nu.vercel.app/Signin
FRONTEND_AUTH_SUCCESS_URL=https://uris-nu.vercel.app/Datasets
FRONTEND_AUTH_ERROR_URL=https://uris-nu.vercel.app/Signin

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://uris.onrender.com/auth/google/callback

# AWS S3 Configuration
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Python Agents Service URL (for profiling)
AGENTS_URL=https://uris-agent.onrender.com
